# ── Server ─────────────────────────────────────────────────────────────
PORT=8080
ALLOWED_ORIGIN=http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────
# Inside docker-compose, host = db (the service name). On a bare metal
# run, swap "db" for "localhost".
DATABASE_URL=postgres://mgm:mgm_dev_password@db:5432/mgm_calendar?sslmode=disable

# Used by the postgres container itself
POSTGRES_USER=mgm
POSTGRES_PASSWORD=mgm_dev_password
POSTGRES_DB=mgm_calendar

# ── Admin auth ─────────────────────────────────────────────────────────
# A single shared password protects the admin panel.
ADMIN_PASSWORD=changeme
# 32+ random bytes recommended; e.g. `openssl rand -hex 48`
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_TTL_HOURS=8

# ── AWS S3 (file uploads + thumbnails) ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=
# Optional. If your bucket is fronted by a CDN, set the public URL prefix
# here, e.g. https://cdn.mgm-lab.id. Otherwise the SDK's virtual-hosted
# URL is used.
S3_PUBLIC_BASE_URL=

# ── Indonesian holiday seeder ──────────────────────────────────────────
# Seeds run once on first boot (tracked via the seeds_log table).
HOLIDAY_API_URL=https://api-harilibur.vercel.app/api
# Set to "false" to skip seeding entirely (useful for tests).
HOLIDAY_SEED_ENABLED=true
